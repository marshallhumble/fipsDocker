# Dockerfile.test
FROM fips-python:3.11.12

WORKDIR /app

COPY requirements.txt /app/
COPY app.py .

RUN openssl list -providers

# Smoke test
RUN python3 - <<EOF
import ssl, sys, traceback
from cryptography.hazmat.primitives import hashes

print(ssl.OPENSSL_VERSION)

try:
    hashes.Hash(hashes.SHA256())
    print('cryptography hash test passed')
except Exception as e:
    print(f'WARNING: cryptography hash test failed: {e}')
    traceback.print_exc(file=sys.stderr)
    sys.exit(1)
EOF

RUN python3 -c "import ssl; print(ssl.OPENSSL_VERSION)"

# Install test-only deps. cryptography is already present in the base image
# built from source. --no-binary-package ensures it is not overwritten by a
# pre-built wheel if pulled as a transitive dep.
RUN uv pip install --system --no-binary cryptography -r requirements.txt

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8080"]